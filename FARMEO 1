	if not anchor then
		return nil
	end

	local bill = PotSystem.esp[container]
	if bill and bill.Parent == nil then
		PotSystem.esp[container] = nil
		bill = nil
	end

	if not bill then
		bill = Instance.new("BillboardGui")
		bill.Name = "PotESP_" .. tostring(index)
		bill.Size = UDim2.new(0, 120, 0, 26)
		bill.StudsOffset = Vector3.new(0, 3.8, 0)

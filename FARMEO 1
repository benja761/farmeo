local function getPotContainerFromPrompt(prompt)
	if not prompt or not prompt.Parent then
		return nil
	end

	local parent = prompt.Parent
	local model = parent:FindFirstAncestorOfClass("Model")
	if model then
		local modelPath = lowerText(buildPath(model))
		if hasAny(model.Name, POT_CONFIG.Keywords) or hasAny(modelPath, POT_CONFIG.Keywords) then
			return model
		end
	end

	local part = parent:FindFirstAncestorWhichIsA("BasePart")
	if part then
		local partPath = lowerText(buildPath(part))
		if hasAny(part.Name, POT_CONFIG.Keywords) or hasAny(partPath, POT_CONFIG.Keywords) then
			return part
		end
	end

	if hasAny(buildPath(parent), POT_CONFIG.Keywords) then
		return parent
	end

	return nil
end

local function getAnchorOfContainer(container)
	if not container then
		return nil
	end

	if container:IsA("BasePart") then
		return container
	end

	if container:IsA("Model") then
		if container.PrimaryPart then
			return container.PrimaryPart
		end
		for _, obj in ipairs(container:GetDescendants()) do
			if obj:IsA("BasePart") then
				return obj
			end
		end
	end

	for _, obj in ipairs(container:GetDescendants()) do
		if obj:IsA("BasePart") then
			return obj
		end
	end

	return nil
end

local function getContainerPos(container)
	local anchor = getAnchorOfContainer(container)
	return anchor and anchor.Position or nil
end

local function getContainerPrompt(container)
	if not container then
		return nil
	end

	for _, obj in ipairs(container:GetDescendants()) do
		if obj:IsA("ProximityPrompt") then
			local path = lowerText(buildPath(obj.Parent))
			if hasAny(path, POT_CONFIG.Keywords) then
				return obj
			end
		end
	end

	return nil
end

local function getExplicitBusyState(container)
	if not container then
		return nil
	end

	local function inspectObject(obj)
		for attrName, value in pairs(obj:GetAttributes()) do
			local attr = lowerText(attrName)
			local val = lowerText(value)

			if hasAny(attr, POT_CONFIG.BusyHints) or hasAny(val, POT_CONFIG.BusyHints) then
				if type(value) == "boolean" then
					return value
				elseif type(value) == "number" then
					return value > 0
				elseif type(value) == "string" then
					if val == "true" or val == "busy" or val == "occupied" or val == "cooking" then
						return true
					elseif val == "false" or val == "free" or val == "idle" then
						return false
					end
				end
			end
		end

		if obj:IsA("BoolValue") and hasAny(obj.Name, POT_CONFIG.BusyHints) then
			return obj.Value
		elseif (obj:IsA("NumberValue") or obj:IsA("IntValue")) and hasAny(obj.Name, POT_CONFIG.BusyHints) then
			return tonumber(obj.Value) > 0
		elseif obj:IsA("StringValue") and (hasAny(obj.Name, POT_CONFIG.BusyHints) or hasAny(obj.Value, POT_CONFIG.BusyHints)) then
			local val = lowerText(obj.Value)
			if val == "free" or val == "idle" then
				return false
			end
			return true
		end

		return nil
	end

	local direct = inspectObject(container)
	if direct ~= nil then
		return direct
	end

	for _, obj in ipairs(container:GetDescendants()) do
		local result = inspectObject(obj)
		if result ~= nil then
			return result
		end
	end

	return nil
end

local function isPotBusy(container)
	local explicit = getExplicitBusyState(container)
	if explicit ~= nil then
		return explicit
	end

	local lockedUntil = PotSystem.localLocks[container]
	if lockedUntil and lockedUntil > tick() then
		return true
	end

	local prompt = getContainerPrompt(container)
	if prompt then
		return not prompt.Enabled
	end

	return true
end


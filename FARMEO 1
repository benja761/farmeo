		txt.Parent = bg

		PotSystem.esp[container] = bill
	end

	bill.Adornee = anchor
	return bill
end

local function refreshPotSystem()
	local found = {}

	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("ProximityPrompt") then
			local container = getPotContainerFromPrompt(obj)
			if container then
				found[container] = true
			end
		end
	end

	local ordered = {}
	for container in pairs(found) do
		local pos = getContainerPos(container)
		if pos then
			table.insert(ordered, {container = container, pos = pos})
		end
	end

	table.sort(ordered, function(a, b)
		return a.pos.Z < b.pos.Z
	end)

	local newCache = {}

	for i, entry in ipairs(ordered) do
		local container = entry.container
		local pos = entry.pos
		local busy = isPotBusy(container)
		local prompt = getContainerPrompt(container)

		newCache[container] = {
			index = i,
			container = container,
			pos = pos,
			busy = busy,
			prompt = prompt,
		}

		local bill = ensurePotBillboard(container, i)
		if bill and bill:FindFirstChild("BG") and bill.BG:FindFirstChild("Label") then
			local label = bill.BG.Label
			local stroke = bill.BG:FindFirstChildOfClass("UIStroke")

			if busy then
				label.Text = "POT " .. i .. " | USED"
				label.TextColor3 = Color3.fromRGB(255, 120, 120)
				if stroke then
					stroke.Color = Color3.fromRGB(255, 120, 120)
				end
			else
				label.Text = "POT " .. i .. " | FREE"
				label.TextColor3 = Color3.fromRGB(120, 255, 170)
				if stroke then
					stroke.Color = Color3.fromRGB(120, 255, 170)
				end
			end
		end
	end

	for container, bill in pairs(PotSystem.esp) do
		if not newCache[container] then
			bill:Destroy()
			PotSystem.esp[container] = nil
		end
	end

	PotSystem.cache = newCache
end

task.spawn(function()
	while true do
		if gui == nil or gui.Parent == nil then
			break
		end
		refreshPotSystem()
		task.wait(POT_CONFIG.RefreshInterval)
	end
end)

local function getStandPosForPot(container)
	local potPos = getContainerPos(container)
	local root = getRoot()
	if not potPos or not root then
		return nil
	end

	local y = root.Position.Y
	local d = POT_CONFIG.StandDistance

	local candidates = {
		Vector3.new(potPos.X + d, y, potPos.Z),
		Vector3.new(potPos.X - d, y, potPos.Z),
		Vector3.new(potPos.X, y, potPos.Z + d),
		Vector3.new(potPos.X, y, potPos.Z - d),
	}

	table.sort(candidates, function(a, b)
		return (a - root.Position).Magnitude < (b - root.Position).Magnitude
	end)

	return candidates[1]
end

local function getBestFreePot()
	refreshPotSystem()

	local root = getRoot()
	if not root then
		return nil
	end

	local freePots = {}

	for _, data in pairs(PotSystem.cache) do
		if not data.busy then
			table.insert(freePots, data)
		end
	end

	table.sort(freePots, function(a, b)
		return (a.pos - root.Position).Magnitude < (b.pos - root.Position).Magnitude
	end)

	return freePots[1]
end

local function interactRawAt(stage, holdSeconds)
	hardStop()
	task.wait(0.08)
	aimAtPrompt(stage.promptPos)
	task.wait(0.08)

	local prompt = findPromptForStage(stage)
	local hold = holdSeconds or stage.holdSeconds or 0.3

	if prompt and prompt.HoldDuration and prompt.HoldDuration > 0 then
		hold = math.max(hold, prompt.HoldDuration + 0.05)
	end

	holdE(hold)
	task.wait(0.06)

	if prompt then
		aimAtPrompt(stage.promptPos)
		fallbackPrompt(prompt, hold)
	else
		tapE()
	end
end

local function runDynamicCookStage(stage, setStatus)
	local chosenPot = nil

	while not stopFlag do
		chosenPot = getBestFreePot()
		if chosenPot then
			break
		end

		setStatus("Estado: Esperando olla libre...", Color3.fromRGB(135, 205, 255))
		if not waitWithStop(0.25) then
			return false
		end
	end

	if not chosenPot then
		return false
	end

	local standPos = getStandPosForPot(chosenPot.container)
	if not standPos then
		return false
	end

	local dynStage = {
		label = "Coccion",
		promptPos = chosenPot.pos,
		promptPathHint = "pot",
		holdSeconds = stage.holdSeconds,
	}

	moveToPoint(standPos, MOVE_TIMEOUT, true)
	if stopFlag then
		return false
	end

	setStatus("Estado: Poniendo en olla", Color3.fromRGB(135, 205, 255))
	interactRawAt(dynStage, stage.holdSeconds)

	PotSystem.localLocks[chosenPot.container] = tick() + POT_CONFIG.LocalLockSeconds

	if not waitWithStop(stage.afterInteractWait or 1.0) then
		return false
	end

	setStatus("Estado: Cocinando 60s", Color3.fromRGB(135, 205, 255))
	if not waitWithStop(stage.cookWaitSeconds or 60) then
		return false
	end

	standPos = getStandPosForPot(chosenPot.container)
	if not standPos then
		return false
	end

	moveToPoint(standPos, MOVE_TIMEOUT, true)
	if stopFlag then
		return false
	end

	setStatus("Estado: Recogiendo olla", Color3.fromRGB(135, 205, 255))
	interactRawAt(dynStage, stage.finalInteractHold or stage.holdSeconds)

	if not waitWithStop(0.9) then
		return false
	end

	return true
end


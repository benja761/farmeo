local function setCoordText(pos)
	if not pos then
		coordBox.Text = "Esperando selección..."
		return
	end

	if roundCoords then
		coordBox.Text = ("X: %d | Y: %d | Z: %d"):format(
			math.round(pos.X), math.round(pos.Y), math.round(pos.Z)
		)
	else
		coordBox.Text = ("X: %.2f | Y: %.2f | Z: %.2f"):format(pos.X, pos.Y, pos.Z)
	end
end

local function createCheckbox(text, order, callback)
	local holder = Instance.new("Frame")
	holder.Parent = checksHolder
	holder.BackgroundTransparency = 1
	holder.Size = UDim2.new(1, 0, 0, 24)
	holder.Position = UDim2.new(0, 0, 0, (order - 1) * 24)

	local box = Instance.new("TextButton")
	box.Parent = holder
	box.Size = UDim2.new(0, 18, 0, 18)
	box.Position = UDim2.new(0, 0, 0, 3)
	box.BackgroundColor3 = Color3.fromRGB(30, 30, 38)
	box.Text = ""
	box.BorderSizePixel = 0
	Instance.new("UICorner", box).CornerRadius = UDim.new(0, 5)

	local fill = Instance.new("Frame")
	fill.Parent = box
	fill.Size = UDim2.new(1, -6, 1, -6)
	fill.Position = UDim2.new(0, 3, 0, 3)
	fill.BackgroundColor3 = Color3.fromRGB(95, 85, 255)
	fill.Visible = false
	fill.BorderSizePixel = 0
	Instance.new("UICorner", fill).CornerRadius = UDim.new(0, 4)

	local label = Instance.new("TextLabel")
	label.Parent = holder
	label.BackgroundTransparency = 1
	label.Position = UDim2.new(0, 26, 0, 0)
	label.Size = UDim2.new(1, -26, 1, 0)
	label.Font = Enum.Font.Gotham
	label.TextColor3 = Color3.fromRGB(230,230,235)
	label.TextSize = 12
	label.TextXAlignment = Enum.TextXAlignment.Left
	label.Text = text

	local state = false

	local function setState(v)
		state = v
		fill.Visible = v
		callback(v)
	end

	box.MouseButton1Click:Connect(function()
		setState(not state)
	end)

	return {
		Set = setState,
		Get = function() return state end
	}
end


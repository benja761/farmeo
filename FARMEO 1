local function setStatus(text, color)
	status.Text = text
	status.TextColor3 = color or Color3.fromRGB(195, 202, 220)
end

local function runLoop()
	if executing then
		return
	end

	executing = true
	stopFlag = false
	setStatus("Estado: EXEC", Color3.fromRGB(135, 205, 255))

	task.spawn(function()
		while executing and not stopFlag do
			for i, stage in ipairs(ROUTE) do
				if stopFlag then
					break
				end

				setStatus("Estado: " .. tostring(stage.label or i), Color3.fromRGB(135, 205, 255))

				if stage.equipKeywords then
					equipForStage(stage)
				end

				for _, point in ipairs(stage.approach or {}) do
					if stopFlag then
						break
					end
					moveToPoint(point, MOVE_TIMEOUT, false)
				end

				if stopFlag then
					break
				end

				if stage.label == "Coccion" then
					if not runDynamicCookStage(stage, setStatus) then
						break
					end
				else
					local done = false

					while not stopFlag and not done do
						setStatus("Estado: Alineando " .. tostring(stage.label), Color3.fromRGB(135, 205, 255))
						done = interactStageVerified(stage)

						if not done then
							setStatus("Estado: Reintentando " .. tostring(stage.label), Color3.fromRGB(255, 205, 135))
							if not waitWithStop(0.15) then
								break
							end
						end
					end

					if stopFlag then
						break
					end

					if not waitWithStop(stage.afterInteractWait or 0.8) then
						break
					end
				end
			end

			if stopFlag then
				break
			end

			task.wait(0.10)
		end

		hardStop()
		executing = false
		stopFlag = false
		setStatus("Estado: OFF", Color3.fromRGB(195, 202, 220))
	end)
end

local function stopExecutor()
	if not executing then
		return
	end

	stopFlag = true
	hardStop()
	setStatus("Estado: STOPPING...", Color3.fromRGB(255, 205, 135))
end


local function lowerText(v)
	return string.lower(tostring(v or ""))
end

local function hasAny(text, list)
	text = lowerText(text)
	for _, word in ipairs(list or {}) do
		if string.find(text, lowerText(word), 1, true) then
			return true
		end
	end
	return false
end

local function hasNone(text, list)
	text = lowerText(text)
	for _, word in ipairs(list or {}) do
		if string.find(text, lowerText(word), 1, true) then
			return false
		end
	end
	return true
end

local function getCharacter()
	return LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
end

local function getHumanoid()
	local char = getCharacter()
	return char:FindFirstChildOfClass("Humanoid")
end

local function getRoot()
	local char = getCharacter()
	return char:FindFirstChild("HumanoidRootPart")
end

local function hardStop()
	local hum = getHumanoid()
	local root = getRoot()
	if hum and root then
		pcall(function()
			hum:MoveTo(root.Position)
		end)
	end
end

local function waitWithStop(seconds)
	local t0 = tick()
	while tick() - t0 < seconds do
		if stopFlag then
			return false
		end
		task.wait(0.05)
	end
	return true
end

local function lookCharacterAt(targetPos)
	local root = getRoot()
	if not root then
		return
	end

	local current = root.Position
	local lookAt = Vector3.new(targetPos.X, current.Y, targetPos.Z)
	if (lookAt - current).Magnitude > 0.1 then
		root.CFrame = CFrame.new(current, lookAt)
	end
end

local function lookCameraAt(targetPos)
	if not Camera then
		return
	end

	local root = getRoot()
	if not root then
		return
	end

	local eye = root.Position + Vector3.new(0, 2.2, 0)
	Camera.CFrame = CFrame.new(eye, targetPos)
end

local function aimAtPrompt(promptPos)
	lookCharacterAt(promptPos)
	task.wait(0.03)
	lookCameraAt(promptPos)
	task.wait(0.03)
	lookCharacterAt(promptPos)
end

local function slowTpTo(targetPos, steps, delayTime)
	local root = getRoot()
	if not root then
		return false
	end

	steps = steps or 10
	delayTime = delayTime or 0.03

	for i = 1, steps do
		if stopFlag then
			return false
		end

		root = getRoot()
		if not root then
			return false
		end

		local current = root.Position
		local nextPos = current:Lerp(targetPos, 0.28)

		local _, y, _ = root.CFrame:ToOrientation()
		root.CFrame = CFrame.new(nextPos) * CFrame.Angles(0, y, 0)

		task.wait(delayTime)
	end

	return true
end

local function moveToPoint(targetPos, timeout, forceArrival)
	local hum = getHumanoid()
	local root = getRoot()
	if not hum or not root then
		return false
	end

	local started = tick()
	local reached = false
	local repathAt = 0
	local lastDist = math.huge
	local stuckSince = nil
	local conn

	conn = hum.MoveToFinished:Connect(function(ok)
		if ok then
			reached = true
		end
	end)

	while tick() - started < timeout do
		if stopFlag then
			if conn then conn:Disconnect() end
			hardStop()
			return false
		end

		hum = getHumanoid()
		root = getRoot()
		if not hum or not root then
			if conn then conn:Disconnect() end
			return false
		end

		local dist = (root.Position - targetPos).Magnitude
		if dist <= REACH_DISTANCE or reached then
			if conn then conn:Disconnect() end
			return true
		end

		if dist >= lastDist - 0.15 then
			if not stuckSince then
				stuckSince = tick()
			end
		else
			stuckSince = nil
		end
		lastDist = dist

		if stuckSince and tick() - stuckSince >= 1.0 and forceArrival then
			if conn then conn:Disconnect() end
			slowTpTo(targetPos, 10, 0.03)
			root = getRoot()
			return root and ((root.Position - targetPos).Magnitude <= REACH_DISTANCE + 1.5) or false
		end

		if tick() >= repathAt then
			repathAt = tick() + REPATH_INTERVAL
			pcall(function()
				hum:MoveTo(targetPos)
			end)
		end

		task.wait(0.05)
	end

	if conn then conn:Disconnect() end

	if forceArrival then
		slowTpTo(targetPos, 12, 0.03)
		root = getRoot()
		return root and ((root.Position - targetPos).Magnitude <= REACH_DISTANCE + 1.5) or false
	end

	return false
end

local function collectTools()
	local tools = {}
	local backpack = LocalPlayer:FindFirstChildOfClass("Backpack")
	local character = LocalPlayer.Character

	local function collect(container)
		if not container then
			return
		end
		for _, obj in ipairs(container:GetChildren()) do
			if obj:IsA("Tool") then
				table.insert(tools, obj)
			end
		end
	end

	collect(backpack)
	collect(character)
	return tools
end

local function getInventoryCounts()
	local counts = {
		potato = 0,
		flour = 0,
		chips = 0,
	}

	for _, tool in ipairs(collectTools()) do
		local name = lowerText(tool.Name)

		if (name == "potato" or name == "patata") and hasNone(name, {"chips", "fried", "frita"}) then
			counts.potato = counts.potato + 1
		elseif name == "flour" or name == "harina" then
			counts.flour = counts.flour + 1
		elseif string.find(name, "potato chips", 1, true) or string.find(name, "chips", 1, true) then
			counts.chips = counts.chips + 1
		end
	end

	return counts
end

local function findToolForStage(stage)
	local tools = collectTools()

	for _, tool in ipairs(tools) do
		local name = lowerText(tool.Name)

		if stage.excludeKeywords and hasAny(name, stage.excludeKeywords) then
			-- ignore
		else
			if hasAny(name, stage.equipKeywords or {}) then
				return tool
			end
		end
	end

	return nil
end

local function equipForStage(stage)
	local hum = getHumanoid()
	if not hum or not stage.equipKeywords then
		return false
	end

	local tool = findToolForStage(stage)
	if not tool then
		return false
	end

	local ok = pcall(function()
		hum:EquipTool(tool)
	end)

	if ok then
		task.wait(0.15)
	end

	return ok
end

local function buildPath(instance)
	local parts = {}
	local current = instance
	local count = 0

	while current and current ~= game and count < 12 do
		table.insert(parts, 1, current.Name)
		current = current.Parent
		count = count + 1
	end

	return table.concat(parts, "/")
end

local function getPromptWorldPosition(prompt)
	if not prompt or not prompt.Parent then
		return nil
	end

	local parent = prompt.Parent

	if parent:IsA("BasePart") then
		return parent.Position
	end

	if parent:IsA("Attachment") then
		return parent.WorldPosition
	end

	local model = parent:FindFirstAncestorOfClass("Model")
	if model then
		if model.PrimaryPart then
			return model.PrimaryPart.Position
		end

		local ok, cf = pcall(function()
			return model:GetPivot()
		end)
		if ok and cf then
			return cf.Position
		end
	end

	local part = parent:FindFirstAncestorWhichIsA("BasePart")
	if part then
		return part.Position
	end

	return nil
end

local function findPromptForStage(stage)
	local bestPrompt = nil
	local bestScore = math.huge

	for _, obj in ipairs(workspace:GetDescendants()) do
		if obj:IsA("ProximityPrompt") and obj.Enabled and obj.Parent then
			local pos = getPromptWorldPosition(obj)
			if pos then
				local dist = (pos - stage.promptPos).Magnitude
				if dist <= PROMPT_RADIUS then
					local score = dist
					if stage.promptPathHint then
						local path = lowerText(buildPath(obj.Parent))
						local hint = lowerText(stage.promptPathHint)
						if not string.find(path, hint, 1, true) then
							score = score + 100
						end
					end

					if score < bestScore then
						bestScore = score
						bestPrompt = obj
					end
				end
			end
		end
	end

	return bestPrompt
end

local function tapE()
	if typeof(keypress) == "function" and typeof(keyrelease) == "function" then
		local ok = pcall(function()
			keypress(0x45)
			task.wait(0.03)
			keyrelease(0x45)
		end)
		if ok then
			return true
		end
	end

	if HAS_VIM and VirtualInputManager then
		return pcall(function()
			VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
			task.wait(0.03)
			VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
		end)
	end

	return false
end

local function holdE(seconds)
	if typeof(keypress) == "function" and typeof(keyrelease) == "function" then
		local ok = pcall(function()
			keypress(0x45)
			task.wait(seconds)
			keyrelease(0x45)
		end)
		if ok then
			return true
		end
	end

	if HAS_VIM and VirtualInputManager then
		return pcall(function()
			VirtualInputManager:SendKeyEvent(true, Enum.KeyCode.E, false, game)
			task.wait(seconds)
			VirtualInputManager:SendKeyEvent(false, Enum.KeyCode.E, false, game)
		end)
	end

	return false
end

local function fallbackPrompt(prompt, seconds)
	if not prompt then
		return false
	end

	if typeof(fireproximityprompt) == "function" then
		return pcall(function()
			fireproximityprompt(prompt, seconds or prompt.HoldDuration or 0)
		end)
	end

	return pcall(function()
		local hold = seconds or 0.08
		if prompt.HoldDuration and prompt.HoldDuration > 0 then
			hold = math.max(hold, prompt.HoldDuration + 0.05)
		end

		prompt:InputHoldBegin()
		task.wait(hold)
		prompt:InputHoldEnd()
	end)
end

local function getAlignCandidates(stage)
	local s = stage.stand or stage.promptPos
	local r = stage.alignRadius or 1.10
	local y = s.Y

	return {
		Vector3.new(s.X, y, s.Z),
		Vector3.new(s.X + r, y, s.Z),
		Vector3.new(s.X - r, y, s.Z),
		Vector3.new(s.X, y, s.Z + r),
		Vector3.new(s.X, y, s.Z - r),
		Vector3.new(s.X + r, y, s.Z + r * 0.6),
		Vector3.new(s.X - r, y, s.Z + r * 0.6),
		Vector3.new(s.X + r, y, s.Z - r * 0.6),
		Vector3.new(s.X - r, y, s.Z - r * 0.6),
	}
end

local function alignUntilPrompt(stage)
	local bestPrompt = nil
	local bestStand = stage.stand or stage.promptPos

	for _, candidate in ipairs(getAlignCandidates(stage)) do
		if stopFlag then
			return nil, bestStand
		end

		moveToPoint(candidate, 2.2, stage.label == "Harina")
		hardStop()
		aimAtPrompt(stage.promptPos)
		task.wait(0.08)

		local prompt = findPromptForStage(stage)
		if prompt then
			bestPrompt = prompt
			bestStand = candidate
			break
		end
	end

	return bestPrompt, bestStand
end

local function waitStageDone(stage, beforeCounts, timeout)
	timeout = timeout or 2.5
	local started = tick()

	if stage.label == "Patata" then
		while tick() - started < timeout do
			if stopFlag then
				return false
			end
			local nowCounts = getInventoryCounts()
			if nowCounts.potato < beforeCounts.potato then
				return true
			end
			task.wait(0.05)
		end
		return false
	elseif stage.label == "Harina" then
		while tick() - started < timeout do
			if stopFlag then
				return false
			end
			local nowCounts = getInventoryCounts()
			if nowCounts.flour < beforeCounts.flour then
				return true
			end
			task.wait(0.05)
		end
		return false
	else
		return waitWithStop(stage.afterInteractWait or 0.6)
	end
end

local function interactStageVerified(stage)
	local tries = stage.maxRetries or 3

	for _ = 1, tries do
		if stopFlag then
			return false
		end

		if stage.equipKeywords then
			equipForStage(stage)
		end

		local beforeCounts = getInventoryCounts()
		local prompt, usedStand = alignUntilPrompt(stage)

		hardStop()
		aimAtPrompt(stage.promptPos)
		task.wait(0.08)

		local hold = stage.holdSeconds or 0.35
		if prompt and prompt.HoldDuration and prompt.HoldDuration > 0 then
			hold = math.max(hold, prompt.HoldDuration + 0.05)
		end

		holdE(hold)
		task.wait(0.06)

		if prompt then
			fallbackPrompt(prompt, hold)
		else
			tapE()
			task.wait(0.05)
			tapE()
		end

		if waitStageDone(stage, beforeCounts, stage.doneTimeout or 2.6) then
			return true
		end

		if usedStand then
			moveToPoint(usedStand + Vector3.new(0, 0, 0.75), 1.8, true)
			hardStop()
			task.wait(0.10)
		end
	end

	return false
end


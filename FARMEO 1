local moving = false
local moveThread = 0

local function getCharacterParts()
	local character = LocalPlayer.Character or LocalPlayer.CharacterAdded:Wait()
	local humanoid = character:FindFirstChildOfClass("Humanoid")
	local root = character:FindFirstChild("HumanoidRootPart")
	if not humanoid or not root then
		return nil, nil, nil
	end
	return character, humanoid, root
end

local function raycastToGround(targetPos)
	local params = RaycastParams.new()
	params.FilterType = Enum.RaycastFilterType.Blacklist

	local character = LocalPlayer.Character
	if character then
		params.FilterDescendantsInstances = {character}
	end

	local origin = targetPos + Vector3.new(0, 50, 0)
	local direction = Vector3.new(0, -200, 0)
	local result = workspace:Raycast(origin, direction, params)

	if result then
		return Vector3.new(targetPos.X, result.Position.Y + 2.5, targetPos.Z)
	end

	return targetPos
end

local function moveSlowlyTo(targetPos)
	local _, humanoid, root = getCharacterParts()
	if not humanoid or not root then return end

	moveThread += 1
	local myThread = moveThread
	moving = true

	humanoid.WalkSpeed = 10

	while myThread == moveThread do
		if not root.Parent or humanoid.Health <= 0 then
			break
		end

		local flatCurrent = Vector3.new(root.Position.X, 0, root.Position.Z)
		local flatTarget = Vector3.new(targetPos.X, 0, targetPos.Z)
		local distance = (flatTarget - flatCurrent).Magnitude

		if distance <= 4 then
			break
		end

		local dir = (flatTarget - flatCurrent).Unit
		local step = math.clamp(distance, 0, 10)
		local nextFlat = flatCurrent + dir * step

		local nextPos = raycastToGround(Vector3.new(nextFlat.X, targetPos.Y, nextFlat.Z))
		humanoid:MoveTo(nextPos)

		local reached = humanoid.MoveToFinished:Wait()
		if not reached then
			task.wait(0.2)
		else
			task.wait(0.05)
		end
	end

	moving = false
end

leftBtn.MouseButton1Click:Connect(function()
